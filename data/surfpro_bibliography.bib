  journaltitle = {Colloids and Surfaces A: Physicochemical and Engineering Aspects},
  shortjournal = {Colloids and Surfaces A: Physicochemical and Engineering Aspects},
  volume = {220},
  number = {1--3},
  pages = {61--68},
  issn = {09277757},
  doi = {10.1016/S0927-7757(03)00060-8},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S0927775703000608},
  urldate = {2026-03-23},
  abstract = {Surface tension measurements were carried out for systems containing mixtures of sodium dodecyl sulphate and sodium hexadecyl sulphonate. From the results of these measurements the mole fraction of sodium hexadecyl sulphonate in a mixed monolayer and in mixed micelles, and the molecular parameters for the formation of mixed micelles and mixed monolayers at water j air interface were determined. Also, the values of the surface tension of the studied systems have been calculated using the relation derived by Joos [Bull. Soc. Chim. Belg., 76 (1967) 591] and compared with the measured values. From this comparison, the adsorption behavior of SDDS and SHDSs mixture can be predicted by the Joos relation, particularly at low surface pressure. The calculated parameters indicate that in the systems of two anionic surfactants no synergism is present in adsorbed monolayers and in the micelle formation, however, a small maximum of the surface concentration excess at water j air interface and a minimum of surface tension corresponding to CMC at a /0.4 and a /0.2 was, respectively, observed.},
  langid = {english}
}

@article{jiao2020,
  title = {Hologram {{QSAR}} Study on the Critical Micelle Concentration of {{Gemini}} Surfactants},
  author = {Jiao, Long and Wang, Yuan and Qu, Le and Xue, Zhiwei and Ge, Yiqing and Liu, Huanhuan and Lei, Bin and Gao, Qian and Li, Mengke},
  date = {2020-02},
  journaltitle = {Colloids and Surfaces A: Physicochemical and Engineering Aspects},
