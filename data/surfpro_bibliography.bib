@article{hussain2017,
  title = {Synthesis and {{Evaluation}} of {{Novel Amido}}‐{{Amine Cationic Gemini Surfactants Containing Flexible}} and {{Rigid Spacers}}},
  author = {Hussain, S. M. Shakil and Kamal, Muhammad Shahzad and El Ali, Bassam and Sultan, Abdullah S.},
  date = {2017-07},
  journaltitle = {Journal of Surfactants and Detergents},
  shortjournal = {J Surfact \& Detergents},
  volume = {20},
