@article{tehrani-bagha2016,
  title = {Cationic Gemini Surfactant with Cleavable Spacer: {{Emulsion}} Stability},
  shorttitle = {Cationic Gemini Surfactant with Cleavable Spacer},
  author = {Tehrani-Bagha, A.R.},
