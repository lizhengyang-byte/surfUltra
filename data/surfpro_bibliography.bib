@article{zhi2014,
  title = {Self-Aggregation and Antimicrobial Activity of Saccharide-Cationic Surfactants},
  author = {Zhi, Lifei and Li, Qiuxiao and Li, Yunling and Sun, Yongqiang},
  date = {2014-08},
