@article{sarikaya2019,
  title = {Investigation of {{Mixing Behavior}} of Both a {{Conventional Surfactant}} and {{Different Inorganic Salts}} with a {{Cationic Gemini Surfactant}} in {{Aqueous Solution}}},
  author = {Sarıkaya, İkbal and Bilgen, Selçuk and Akbaş, Halide},
  date = {2019-11},
  journaltitle = {Journal of Surfactants and Detergents},
