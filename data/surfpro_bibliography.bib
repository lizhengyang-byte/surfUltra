  author = {Kamboj, Raman and Singh, Sukhprit and Bhadani, Avinash and Kataria, Hardeep and Kaur, Gurcharan},
  date = {2012-08-21},
  journaltitle = {Langmuir},
  shortjournal = {Langmuir},
  volume = {28},
  number = {33},
