@article{okawauchi1987,
  title = {A {{Light-Scattering Study}} of {{Temperature Effect}} on {{Micelle Formation}} of {{{\mkbibemph{N}}}} -{{Alkanoyl-}} {{{\mkbibemph{N}}}} -Methylglucamines in {{Aqueous Solution}}},
