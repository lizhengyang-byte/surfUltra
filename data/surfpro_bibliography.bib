@article{roy2005,
  title = {Giant Vesicles of a Single-Tailed Chiral Cationic Surfactant, ({{1R}},{{2S}})-(–)-{{N-dodecyl-N-methylephedrinium}} Bromide, in Water},
  author = {Roy, Sumita and Khatua, Dibyendu and Dey, Joykrishna},
  date = {2005-12},
  journaltitle = {Journal of Colloid and Interface Science},
  shortjournal = {Journal of Colloid and Interface Science},
