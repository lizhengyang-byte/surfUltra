  issn = {0009-2673, 1348-0634},
  doi = {10.1246/bcsj.60.2719},
  url = {https://academic.oup.com/bcsj/article/60/8/2719/7364964},
  urldate = {2026-03-23},
  abstract = {Abstract             The physicochemical properties of N-alkanoyl-N-methylglucamine in aqueous solution have been studied by applying a Debye plot and small-system thermodynamics to an analysis of static light scattering data in the temperature range from 25 to 55 °C. A small minimum was found in a plot of the critical micelle concentration vs. temperature, instead of the monotonously decreasing tendency, as in the case of poly(oxyethylene) alkyl ether. The temperature dependence of the aggregation number of the micelle and the spread of the aggregation number distribution of micelle are both very small. The standard enthalpy change associated with micelle formation varies from positive to negative as the temperature is raised. The micellization of N-alkanoyl-N-methylglucamine surfactants is discussed separately in terms of the respective contributions from the hydrophilic and hydrophobic groups.},
  langid = {english}
}

